{
  "name": "turbogixxer.site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <27",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:shop": "node scripts/verify-shop-catalog.mjs",
    "setup:cloud": "sh scripts/setup-cloud.sh",
    "maintain:cloud": "sh scripts/setup-cloud.sh",
    "validate": "sh scripts/validate-cloud.sh",
    "validate:cloud": "npm run validate"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.15.34",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.30.1",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
